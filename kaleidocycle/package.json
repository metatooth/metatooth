{
  "name": "kaleidocycle",
  "version": "0.0.0",
  "description": "A ring of tetrahedra",
  "engines": {
    "node": "20.18.1",
    "npm": "11.14.1"
  },
  "main": "index.js",
  "scripts": {
    "start": "nodemon ./index.js",
    "dev": "concurrently \"nodemon ./index.js\" \"browser-sync start --proxy 'localhost:5000' --files 'public/**/*' --port 3000 --no-open\"",
    "test": "node test.js",
    "lint": "node_modules/eslint/bin/eslint.js **/*.js --ignore-pattern node_modules/"
  },
  "dependencies": {
    "express": "^4.15.2"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.0",
    "eslint": "^8.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.19.1",
    "nodemon": "^3.1.7",
    "prettier": "3.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/metatooth/kaleidocycle"
  },
  "nodemonConfig": {
    "ignore": [
      "**/node_modules/**"
    ],
    "delay": 2500
  },
  "keywords": [
    "node",
    "heroku",
    "express"
  ],
  "license": "MIT"
}
