[global]

error_log = /proc/self/fd/2
daemonize = no

[www]

access.log = /proc/self/fd/2

listen = /sock/docker.sock
listen.owner = app
listen.group = app
listen.mode = 0666

pm = dynamic
pm.max_children = 10
pm.start_servers = 4
pm.min_spare_servers = 2
pm.max_spare_servers = 6

clear_env = no
catch_workers_output = yes
