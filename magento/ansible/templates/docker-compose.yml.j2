services:
  {{ site_slug }}_php:
    image: markoshust/magento-php:8.3-fpm-0
    container_name: php-{{ site_slug }}-1
    restart: unless-stopped
    volumes:
      - {{ build_dir }}/public_html:/var/www/html
      - {{ build_dir }}/php-fpm.conf:/usr/local/etc/php-fpm.conf
      - {{ site_slug }}_sock:/sock
    depends_on:
      - {{ site_slug }}_opensearch

  {{ site_slug }}_nginx:
    image: nginx:1.24-alpine
    container_name: nginx-{{ site_slug }}-1
    restart: unless-stopped
    ports:
      - "{{ magento_port }}:80"
    volumes:
      - {{ build_dir }}/public_html:/var/www/html
      - {{ build_dir }}/nginx.conf:/etc/nginx/conf.d/default.conf
      - {{ site_slug }}_sock:/sock
    depends_on:
      - {{ site_slug }}_php

  {{ site_slug }}_opensearch:
    image: opensearchproject/opensearch:3
    container_name: opensearch-{{ site_slug }}-1
    restart: unless-stopped
    environment:
      - discovery.type=single-node
      - DISABLE_SECURITY_PLUGIN=true
      - "OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m"
    volumes:
      - {{ site_slug }}_opensearch_data:/usr/share/opensearch/data

volumes:
  {{ site_slug }}_sock:
  {{ site_slug }}_opensearch_data:
