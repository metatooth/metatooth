{
  "name": "herbert-api",
  "scripts": {
    "copy:favicon": "mkdir -p ../../dist/api && cp favicon.ico ../../dist/api/favicon.ico",
    "build": "npm run copy:favicon && tsc",
    "serve": "npm run copy:favicon && tsc-watch --noClear --onSuccess \"node --enable-source-maps ../../dist/api/main.js\""
  },
  "dependencies": {
    "pg": "^8.12.0",
    "express": "^4.17.1"
  },
  "devDependencies": {
    "@types/pg": "^8.5.1"
  }
}
