{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "es2022",
    "lib": ["dom"],
    "paths": {
      "@shared/*": ["../shared/*"],
      "@client/*": ["./*"]
    },
    "outDir": "../../dist/client",
    "composite": true
  },
  "include": ["**/*.ts", "**/*.vue"],
  "exclude": ["**/*.test.ts"],
  "references": [{ "path": "../shared" }]
}
